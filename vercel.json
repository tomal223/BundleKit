{
  "buildCommand": "npx prisma generate && npm run build",
  "installCommand": "npm install --ignore-scripts && node scripts/postinstall.js",
  "outputDirectory": "build/client",
  "regions": ["sin1"],
  "env": {
    "NODE_ENV": "production"
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/index" }
  ]
}
